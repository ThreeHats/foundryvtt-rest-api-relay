---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Subscription Cancelled - Foundry REST API">
  <div class="status-page">
    <div class="status-card">
      <div class="status-icon cancel">&#10005;</div>
      <h1>Subscription Cancelled</h1>
      <p>You've cancelled the subscription process.</p>
      <p class="text-muted">You can subscribe any time to get unlimited API access.</p>
      <a href="/" class="btn btn-primary mt-2">Return to Dashboard</a>
      <p class="redirect-note">Redirecting automatically in 5 seconds...</p>
    </div>
  </div>
</BaseLayout>

<script>
  setTimeout(() => { window.location.href = '/'; }, 5000);
</script>

<style>
  .status-page {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
    padding: 2rem;
  }

  .status-card {
    text-align: center;
    max-width: 480px;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 3rem 2rem;
    box-shadow: var(--shadow-md);
  }

  .status-icon {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    margin-bottom: 1.5rem;
  }

  .status-icon.cancel {
    background: var(--color-warning-bg);
    color: var(--color-warning);
  }

  h1 {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  p {
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .redirect-note {
    margin-top: 1.5rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
</style>
