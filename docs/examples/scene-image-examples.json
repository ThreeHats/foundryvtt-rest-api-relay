    "codeExamples": {
      "javascript": "const baseUrl = 'http://localhost:3011';\nconst path = '/scene/image';\nconst params = {\n  clientId: 'qsl-integration-test',\n  format: 'png'\n};\nconst queryString = new URLSearchParams(params).toString();\nconst url = `${baseUrl}${path}?${queryString}`;\n\nconst response = await fetch(url, {\n  method: 'GET',\n  headers: {\n    'x-api-key': 'c2f25bfd78a7fe3e7b3294dbf5f026285989fa0d7f7b73b2108305e68f64b796'\n  }\n});\nconst data = await response.json();\nconsole.log(data);",
