# ========================================
# FoundryVTT REST API Relay — Server Configuration
# ========================================
# Copy this file to .env and adjust values for your setup.

# ========================================
# Core
# ========================================

# Server port
# Default: 3010
PORT=3010

# Environment mode ("development" or "production")
# Production enables SSL for PostgreSQL connections
# Default: development
NODE_ENV=development

# Database backend: "memory" (dev, no persistence), "sqlite" (local), "postgres" (production)
# Default: postgres
DB_TYPE=sqlite

# PostgreSQL connection string (required when DB_TYPE=postgres)
DATABASE_URL=postgresql://postgres:password@localhost:5432/foundryvtt_api

# Log level: "debug", "info", "warn", "error"
# Default: info
LOG_LEVEL=info

# ========================================
# Auth
# ========================================

# Auto-create an admin user on startup (optional)
# If set, registers this user if they don't already exist
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=SecurePassword1

# Disable new user registration (for private/staging environments)
# Default: false
DISABLE_REGISTRATION=false

# AES-256 encryption key for storing Foundry credentials on scoped API keys
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set, scoped keys cannot store Foundry credentials
# CREDENTIALS_ENCRYPTION_KEY=

# ========================================
# Rate Limiting
# ========================================

# Max requests per IP for auth endpoints (register, login, regenerate-key)
# Window: 15 minutes
# Default: 5
# AUTH_RATE_LIMIT=5

# Max requests per IP for password reset endpoints
# Window: 1 hour
# Default: 3
# PASSWORD_RESET_RATE_LIMIT=3

# Max requests per IP for account management endpoints (change-password, export-data, delete account)
# Window: 1 hour
# Default: 10
# ACCOUNT_MGMT_RATE_LIMIT=10

# Return raw password reset token in the forgot-password response (for testing only!)
# NEVER enable this in production — it bypasses the email verification step.
# Default: false
# RETURN_RESET_TOKEN=true

# ========================================
# API Usage Limits
# ========================================

# Monthly API request limit for free-tier users
# Default: 100
FREE_API_REQUESTS_LIMIT=100

# Daily API request limit for all users
# Default: 1000
DAILY_REQUEST_LIMIT=1000

# ========================================
# Stripe (Subscription Billing)
# ========================================
# Stripe is disabled when STRIPE_SECRET_KEY is not set.
# Use sk_test_ keys for development, sk_live_ for production.

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...

# Shared Stripe Customer Portal URL (from Stripe Dashboard > Settings > Customer portal)
# STRIPE_PORTAL_URL=https://billing.stripe.com/p/login/...

# Base URL for checkout success/cancel redirects
# Default: (empty)
FRONTEND_URL=http://localhost:3010

# ========================================
# Redis (Multi-Instance Routing)
# ========================================
# Optional. Enables cross-instance client routing for Fly.io deployments.
# Automatically disabled when DB_TYPE is "memory" or "sqlite".

# REDIS_URL=redis://default:password@host:6379
# REDIS_ENABLED=true

# ========================================
# Email (Password Reset, Notifications)
# ========================================
# Required for password reset emails. If not configured, reset tokens
# are logged to the console instead.

# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Foundry REST API <noreply@example.com>
# SMTP_SECURE=false

# ========================================
# WebSocket Tuning
# ========================================

# Keepalive ping interval for WebSocket connections (ms)
# Default: 20000
# WEBSOCKET_PING_INTERVAL_MS=20000

# Interval to check for and remove dead client connections (ms)
# Default: 15000
# CLIENT_CLEANUP_INTERVAL_MS=15000

# ========================================
# Headless Sessions (Puppeteer/Chrome)
# ========================================

# Allow headless browser sessions (set to false to completely disable)
# Default: true
# ALLOW_HEADLESS=true

# Max concurrent headless browser sessions
# Default: 1
# MAX_HEADLESS_SESSIONS=1

# Max interactive sheet sessions per scoped API key
# Default: 3
# MAX_SHEET_SESSIONS_PER_KEY=3

# Path to Chrome/Chromium executable (auto-detected if not set)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Capture browser console output from headless sessions
# Values: "error" (errors only), "warn" (errors + warnings), "debug" (all)
# Logs saved to data/browser-logs/
# CAPTURE_BROWSER_CONSOLE=warn

# Require paid subscription for headless session creation
# Default: false
# REQUIRE_PAID_HEADLESS=false

# ========================================
# Fly.io Deployment (Production)
# ========================================
# These are typically set automatically by Fly.io.

# FLY_ALLOC_ID=local
# FLY_INTERNAL_PORT=3010
# APP_NAME=foundryvtt-rest-api-relay
