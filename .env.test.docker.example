# Env file for Docker-based integration tests (scripts/test-docker.sh).
# Copy to .env.test.docker (or point ENV_FILE at any file with these vars —
# e.g. an existing quicksilvervtt-lite .env, which uses the same names).
# Do NOT commit real credentials.

# ========================================
# Required: foundryvtt.com account
# Used by quicksilvervtt-lite to download Foundry VTT. Same variable names as a
# quicksilvervtt-lite .env. This is your foundryvtt.com login — NOT the in-world
# GM login (that is "Gamemaster", passwordless, set automatically by the script).
# ========================================
FOUNDRY_USERNAME=you@example.com
FOUNDRY_PASSWORD=your-foundryvtt-password

# ========================================
# Optional
# ========================================
# Path to your foundryvtt-rest-api checkout (default: ../foundryvtt-rest-api)
# MODULE_PATH=/path/to/foundryvtt-rest-api

# Relay encryption secrets (auto-generated per run if unset)
# CREDENTIALS_ENCRYPTION_KEY=   # openssl rand -hex 32
# ADMIN_JWT_SECRET=             # openssl rand -base64 32

# Leave the stack running after tests for debugging
# KEEP_RUNNING=1
